<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vendor Dashboard - Crescent</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('includes/navbar') %>

    <div class="container-fluid mt-5">
        <h2>Vendor Dashboard</h2>

        <% if (error) { %>
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                <%= error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>

        <% if (vendor) { %>
            <div class="row mt-4">
                <div class="col-md-6">
                    <div class="card p-4">
                        <h5><%= vendor.businessName %></h5>
                        <p>📧 <%= vendor.email %></p>
                        <p>📱 <%= vendor.phone %></p>
                        <p>📍 <%= vendor.address %></p>
                        <p>⭐ Vendor Rating: 
                           <strong id="vendorRating"><%= (vendor.rating || 0).toFixed(1) %> out of 5</strong>
                        </p>
                        <p class="text-muted text-sm">Based on customer ratings of your products</p>
                        <p>📦 Total Orders: <%= vendor.totalOrders %></p>
                        
                        <!-- Verification Status -->
                        <div class="mt-3">
                            <% if (vendor.isVerified) { %>
                                <div class="alert alert-success">
                                    <h6>✅ Your account is verified!</h6>
                                    <p>You can now sell products on Blinkit.</p>
                                </div>
                            <% } else { %>
                                <div class="alert alert-warning">
                                    <h6>⏳ Your account is pending verification</h6>
                                    <p>Admin will review and verify your account soon.</p>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>

            <h4 class="mt-5">Your Products</h4>
            <a href="/vendor/add-product" class="btn btn-success mb-3">
                ➕ Add New Product
            </a>

            <div class="row">
                <% if (products && products.length > 0) { %>
                    <% products.forEach(product => { %>
                        <div class="col-md-4 col-sm-6 col-12 mb-4">
                            <div class="card h-100">
                                <img src="<%= product.image %>" class="card-img-top" alt="<%= product.name %>" onerror="this.src='https://via.placeholder.com/300x200?text=Product'" style="height: 200px; object-fit: cover;">
                                <div class="card-body">
                                    <h5 class="card-title"><%= product.name %></h5>
                                    <p class="text-success fw-bold">₹<%= product.price %></p>
                                    <p class="text-muted">Stock: <strong><%= product.stock %></strong></p>
                                    <p class="text-muted">Category: <%= product.category %></p>
                                </div>
                                <div class="card-footer bg-light">
                                    <button class="btn btn-sm btn-danger w-100" onclick="deleteProduct('<%= product._id %>')">
                                        🗑️ Delete
                                    </button>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div class="col-12">
                        <div class="alert alert-info">
                            <p>📦 No products added yet</p>
                            <a href="/vendor/add-product" class="btn btn-primary">Add Your First Product</a>
                        </div>
                    </div>
                <% } %>
            </div>
        <% } else { %>
            <div class="alert alert-info mt-4">
                <h5>You are not a vendor yet</h5>
                <p>To become a vendor and start selling, please <a href="/signup">register as a vendor</a></p>
            </div>
        <% } %>

        <a href="/" class="btn btn-secondary mt-4">Back to Home</a>
    </div>

    <%- include('includes/footer') %>

    <script>
        async function deleteProduct(productId) {
            if (!confirm('Are you sure you want to delete this product?')) return;

            try {
                const response = await fetch(`/vendor/delete-product/${productId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });

                const data = await response.json();

                if (data.success) {
                    alert('Product deleted successfully!');
                    location.reload();
                } else {
                    alert('Error: ' + data.message);
                }
            } catch (err) {
                alert('Error: ' + err.message);
            }
        }
    </script>
</body>
</html>