<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Payment Failed - Crescent</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('includes/navbar') %>

    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card text-center p-5 shadow-lg border-danger">
                    <div style="font-size: 4rem; margin-bottom: 20px;">❌</div>
                    <h2 class="text-danger mb-3">Payment Failed</h2>
                    
                    <div class="alert alert-danger">
                        <h5>Transaction Unsuccessful</h5>
                        <p class="mb-0">Order #<%= order.orderNumber %></p>
                    </div>

                    <p class="text-muted mb-4">
                        Your payment could not be processed. Please try again or contact support.
                    </p>

                    <div class="bg-light p-4 rounded mb-4">
                        <h6 class="mb-3">Order Details</h6>
                        <p class="mb-2">
                            <strong>Amount:</strong> 
                            <span class="float-end">₹<%= order.totalAmount.toFixed(2) %></span>
                        </p>
                        <p class="mb-0">
                            <strong>Status:</strong>
                            <span class="float-end badge bg-warning">Pending</span>
                        </p>
                    </div>

                    <div class="d-grid gap-2">
                        <a href="/cart" class="btn btn-primary btn-lg">
                            🛒 Back to Cart
                        </a>
                        <a href="/" class="btn btn-outline-secondary">
                            🏠 Go to Home
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('includes/footer') %>
</body>
</html>