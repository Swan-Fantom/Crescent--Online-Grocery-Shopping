<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Vendors - Crescent Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('includes/navbar') %>

    <div class="container-fluid mt-5">
        <h2>Manage Vendors</h2>

        <% if (error) { %>
            <div class="alert alert-danger"><%= error %></div>
        <% } %>

        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Business Name</th>
                        <th>Owner</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Status</th>
                        <th>Rating</th>
                        <th>Orders</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (vendors && vendors.length > 0) { %>
                        <% vendors.forEach(vendor => { %>
                            <tr>
                                <td><strong><%= vendor.businessName %></strong></td>
                                <td><%= vendor.owner.username %></td>
                                <td><%= vendor.email %></td>
                                <td><%= vendor.phone %></td>
                                <td>
                                    <% if (vendor.isVerified) { %>
                                        <span class="badge bg-success">✅ Verified</span>
                                    <% } else { %>
                                        <span class="badge bg-warning">⏳ Pending</span>
                                    <% } %>
                                </td>
                                <td>⭐ <%= vendor.rating %></td>
                                <td><%= vendor.totalOrders %></td>
                                <td>
                                    <% if (!vendor.isVerified) { %>
                                        <button class="btn btn-sm btn-success" onclick="verifyVendor('<%= vendor._id %>')">
                                            ✅ Verify
                                        </button>
                                    <% } else { %>
                                        <button class="btn btn-sm btn-warning" onclick="rejectVendor('<%= vendor._id %>')">
                                            ❌ Reject
                                        </button>
                                    <% } %>
                                    <button class="btn btn-sm btn-danger" onclick="deleteVendor('<%= vendor._id %>')">
                                        🗑️ Delete
                                    </button>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="8" class="text-center text-muted">No vendors found</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <a href="/admin" class="btn btn-secondary mt-3">Back to Admin</a>
    </div>

    <%- include('includes/footer') %>

    <script>
        async function verifyVendor(vendorId) {
            if (!confirm('Are you sure you want to verify this vendor?')) return;

            try {
                const response = await fetch(`/admin/verify-vendor/${vendorId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });

                const data = await response.json();

                if (data.success) {
                    alert('Vendor verified successfully!');
                    location.reload();
                } else {
                    alert('Error: ' + data.message);
                }
            } catch (err) {
                alert('Error: ' + err.message);
            }
        }

        async function rejectVendor(vendorId) {
            if (!confirm('Are you sure you want to reject this vendor?')) return;

            try {
                const response = await fetch(`/admin/reject-vendor/${vendorId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });

                const data = await response.json();

                if (data.success) {
                    alert('Vendor rejected!');
                    location.reload();
                } else {
                    alert('Error: ' + data.message);
                }
            } catch (err) {
                alert('Error: ' + err.message);
            }
        }

        async function deleteVendor(vendorId) {
            if (!confirm('Are you sure you want to DELETE this vendor? This cannot be undone!')) return;

            try {
                const response = await fetch(`/admin/delete-vendor/${vendorId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });

                const data = await response.json();

                if (data.success) {
                    alert('Vendor deleted!');
                    location.reload();
                } else {
                    alert('Error: ' + data.message);
                }
            } catch (err) {
                alert('Error: ' + err.message);
            }
        }
    </script>
</body>
</html>