<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Details - Crescent</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('includes/navbar') %>

    <div class="container mt-5">
        <h2>Order Details</h2>

        <div class="row mt-4">
            <div class="col-md-8">
                <div class="card p-4">
                    <h5>Order Number: <%= order.orderNumber %></h5>
                    <hr>
                    
                    <p>
                        <strong>Status:</strong>
                        <span class="badge bg-<%= order.status === 'Delivered' ? 'success' : order.status === 'Cancelled' ? 'danger' : 'warning' %>">
                            <%= order.status %>
                        </span>
                    </p>

                    <p><strong>Delivery Address:</strong> <%= order.deliveryAddress %></p>
                    <p><strong>Ordered on:</strong> <%= new Date(order.createdAt).toLocaleDateString() %></p>

                    <% if (order.deliveryPerson) { %>
                        <p><strong>Delivery Person:</strong> <%= order.deliveryPerson.username %> (📱 <%= order.deliveryPerson.phone %>)</p>
                    <% } %>

                    <h5 class="mt-4">Items Ordered:</h5>
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Quantity</th>
                                <th>Price</th>
                                <th>Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (order.items && order.items.length > 0) { %>
                                <% order.items.forEach(item => { %>
                                    <tr>
                                        <td>
                                            <% if (item.product) { %>
                                                <%= item.product.name %>
                                            <% } else { %>
                                                <span class="text-muted">[Product Deleted]</span>
                                            <% } %>
                                        </td>
                                        <td><%= item.quantity %></td>
                                        <td>₹<%= item.price %></td>
                                        <td>₹<%= item.price * item.quantity %></td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="4" class="text-center text-muted">No items in this order</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card p-4">
                    <h5>Order Summary</h5>
                    <hr>
                    <p>Subtotal: ₹<%= order.totalAmount - 50 %></p>
                    <p>Delivery Fee: ₹50</p>
                    <h4>Total: ₹<%= order.totalAmount %></h4>

                    <a href="/orders" class="btn btn-primary w-100 mt-3">Back to Orders</a>
                </div>
            </div>
        </div>
    </div>

    <%- include('includes/footer') %>
</body>
</html>