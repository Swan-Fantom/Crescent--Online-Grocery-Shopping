<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shopping Cart - Crescent</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('includes/navbar') %>

    <div class="container mt-5">
        <h2>🛒 Shopping Cart</h2>

        <% if (error) { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <%= error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>

        <% if (cart && cart.length > 0) { %>
            <div class="row mt-4">
                <div class="col-md-8">
                    <div class="card">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Product</th>
                                    <th>Price</th>
                                    <th>Quantity</th>
                                    <th>Total</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% let cartTotal = 0; %>
                                <% cart.forEach(item => { %>
                                    <% const itemTotal = item.price * item.quantity; %>
                                    <% cartTotal += itemTotal; %>
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <img src="<%= item.image %>" alt="<%= item.name %>" style="width: 60px; height: 60px; object-fit: cover; border-radius: 5px; margin-right: 10px;" onerror="this.src='https://via.placeholder.com/60x60?text=Product'">
                                                <div>
                                                    <h6 class="mb-0"><%= item.name %></h6>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <strong>₹<%= item.price %></strong>
                                        </td>
                                        <td>
                                            <span class="badge bg-primary"><%= item.quantity %></span>
                                        </td>
                                        <td>
                                            <strong class="text-success">₹<%= itemTotal %></strong>
                                        </td>
                                        <td>
                                            <form method="POST" action="/cart/remove/<%= item.productId %>" style="display:inline;">
                                                <button type="submit" class="btn btn-sm btn-danger" title="Remove from cart">
                                                    🗑️
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>

                    <div class="mt-3">
                        <a href="/products" class="btn btn-outline-primary">← Continue Shopping</a>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card p-4 sticky-top" style="top: 20px;">
                        <h5 class="mb-3">💰 Price Details</h5>
                        <hr>

                        <div class="d-flex justify-content-between mb-2">
                            <span>Subtotal (<%= cart.length %> items):</span>
                            <span>₹<%= cartTotal %></span>
                        </div>

                        <div class="d-flex justify-content-between mb-2">
                            <span>Delivery Fee:</span>
                            <span class="text-success">₹50</span>
                        </div>

                        <div class="d-flex justify-content-between mb-3">
                            <span>Discount:</span>
                            <span class="text-danger">₹0</span>
                        </div>

                        <hr>

                        <div class="d-flex justify-content-between mb-4">
                            <h6 class="mb-0">Total Amount:</h6>
                            <h6 class="mb-0 text-success"><strong>₹<%= cartTotal + 50 %></strong></h6>
                        </div>

                        <form method="POST" action="/cart/checkout" id="checkoutForm">
                            <div class="mb-3">
                                <label class="form-label"><strong>Delivery Address *</strong></label>
                                <textarea name="deliveryAddress" class="form-control" rows="4" placeholder="Enter your complete delivery address (House No., Street, City, Postal Code)" required style="resize: none;"></textarea>
                                <small class="text-danger" id="addressError"></small>
                            </div>

                            <button type="submit" class="btn btn-success btn-lg w-100 mb-2">
                                💳 Proceed to Payment
                            </button>
                        </form>

                        <button type="button" class="btn btn-outline-secondary w-100" onclick="continueShopping()">
                            Continue Shopping
                        </button>

                        <div class="mt-3 p-3 bg-light rounded">
                            <small class="text-muted">
                                <strong>✅ Safe & Secure:</strong> Your payment is protected by SSL encryption
                            </small>
                        </div>
                    </div>
                </div>
            </div>

        <% } else { %>
            <div class="row mt-4">
                <div class="col-md-8 offset-md-2">
                    <div class="card text-center p-5">
                        <div style="font-size: 4rem; margin-bottom: 20px;">🛒</div>
                        <h4>Your Cart is Empty</h4>
                        <p class="text-muted mb-4">Start shopping to fill your cart with fresh groceries!</p>
                        
                        <a href="/products" class="btn btn-success btn-lg">
                            🛍️ Start Shopping
                        </a>
                    </div>
                </div>
            </div>
        <% } %>
    </div>

    <%- include('includes/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Form validation
        document.getElementById('checkoutForm').addEventListener('submit', function(e) {
            const address = document.querySelector('textarea[name="deliveryAddress"]').value.trim();
            const addressError = document.getElementById('addressError');

            // Clear previous error
            addressError.textContent = '';

            // Validation checks
            if (address.length < 10) {
                addressError.textContent = '❌ Address must be at least 10 characters long';
                e.preventDefault();
                return false;
            }

            if (address.length > 500) {
                addressError.textContent = '❌ Address cannot exceed 500 characters';
                e.preventDefault();
                return false;
            }

            // Check if address has required parts
            const hasNumber = /\d/.test(address);
            const hasComma = address.includes(',');

            if (!hasNumber) {
                addressError.textContent = '⚠️ Address should include a building/house number';
                e.preventDefault();
                return false;
            }

            if (!hasComma) {
                addressError.textContent = '⚠️ Please use commas to separate address parts (e.g., House, Street, City)';
                e.preventDefault();
                return false;
            }

            return true;
        });

        // Continue shopping function
        function continueShopping() {
            window.location.href = '/products';
        }

        // Real-time address validation
        document.querySelector('textarea[name="deliveryAddress"]').addEventListener('input', function() {
            const address = this.value.trim();
            const addressError = document.getElementById('addressError');

            if (address.length > 500) {
                addressError.textContent = '⚠️ Address is too long';
            } else {
                addressError.textContent = '';
            }
        });

        // Show notification on page load if coming from products
        window.addEventListener('load', function() {
            if (document.querySelectorAll('.alert').length > 0) {
                // Alert already shown
            }
        });
    </script>
</body>
</html>