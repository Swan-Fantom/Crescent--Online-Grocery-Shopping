<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Products - Crescent Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('includes/navbar') %>

    <div class="container-fluid mt-5">
        <h2>Manage Products</h2>

        <a href="/admin/add-product" class="btn btn-primary mb-3">Add New Product</a>

        <% if (error) { %>
            <div class="alert alert-danger"><%= error %></div>
        <% } %>

        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Product Name</th>
                        <th>Category</th>
                        <th>Price</th>
                        <th>Stock</th>
                        <th>Vendor</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (products && products.length > 0) { %>
                        <% products.forEach(product => { %>
                            <tr>
                                <td><%= product.name %></td>
                                <td><%= product.category %></td>
                                <td>₹<%= product.price %></td>
                                <td><%= product.stock %></td>
                                <td><%= product.vendor ? product.vendor.businessName : 'N/A' %></td>
                                <td>
                                    <button class="btn btn-sm btn-warning">Edit</button>
                                    <button class="btn btn-sm btn-danger" onclick="deleteProduct('<%= product._id %>')">Delete</button>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="6" class="text-center text-muted">No products found</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <a href="/admin" class="btn btn-secondary mt-3">Back to Admin</a>
    </div>

    <%- include('includes/footer') %>
    <script src="/js/main.js"></script>
</body>
</html>