<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Crescent - Online Grocery Store</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('includes/navbar') %>

    <div class="container mt-5">
        <% if (notification) { %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <%= notification %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>

        <div class="jumbotron bg-light p-5 text-center">
            <h1 class="display-4">Welcome to Crescent</h1>
            <p class="lead">Get Fresh Groceries Delivered in 10 Minutes!</p>
            <a href="/products" class="btn btn-primary btn-lg">Shop Now</a>
        </div>

        <div class="row mt-5">
            <div class="col-md-3 text-center">
                <div class="feature-box p-3 bg-light rounded">
                    <h5>🚚 Fast Delivery</h5>
                    <p>In just 10 minutes</p>
                </div>
            </div>
            <div class="col-md-3 text-center">
                <div class="feature-box p-3 bg-light rounded">
                    <h5>💚 Fresh Products</h5>
                    <p>Quality guaranteed</p>
                </div>
            </div>
            <div class="col-md-3 text-center">
                <div class="feature-box p-3 bg-light rounded">
                    <h5>💰 Best Prices</h5>
                    <p>Great deals everyday</p>
                </div>
            </div>
            <div class="col-md-3 text-center">
                <div class="feature-box p-3 bg-light rounded">
                    <h5>🔒 Safe & Secure</h5>
                    <p>Secure transactions</p>
                </div>
            </div>
        </div>
    </div>

    <%- include('includes/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
</body>
</html>