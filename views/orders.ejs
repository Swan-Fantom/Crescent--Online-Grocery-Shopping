<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Orders - Crescent</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('includes/navbar') %>

    <div class="container mt-5">
        <h2>My Orders</h2>

        <% if (orders && orders.length > 0) { %>
            <div class="row mt-4">
                <% orders.forEach(order => { %>
                    <div class="col-md-6 mb-4">
                        <div class="card">
                            <div class="card-body">
                                <h5 class="card-title"><%= order.orderNumber %></h5>
                                <p class="card-text">
                                    <strong>Status:</strong> 
                                    <span class="badge bg-<%= order.status === 'Delivered' ? 'success' : order.status === 'Cancelled' ? 'danger' : 'warning' %>">
                                        <%= order.status %>
                                    </span>
                                </p>
                                <p class="card-text">
                                    <strong>Amount:</strong> ₹<%= order.totalAmount %>
                                </p>
                                <p class="card-text">
                                    <strong>Delivery Address:</strong> <%= order.deliveryAddress %>
                                </p>
                                <p class="card-text text-muted">
                                    <small>Ordered on: <%= new Date(order.createdAt).toLocaleDateString() %></small>
                                </p>
                                <a href="/orders/<%= order._id %>" class="btn btn-sm btn-info">View Details</a>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } else { %>
            <div class="alert alert-info mt-4">
                No orders yet. <a href="/products">Start Shopping</a>
            </div>
        <% } %>
    </div>

    <%- include('includes/footer') %>
</body>
</html>